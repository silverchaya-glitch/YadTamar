PORT=3000

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=yadtamar
PGUSER=yadtamar
PGPASSWORD=

# HYP (כספית) — מפתחות מ-dashboard.hyp.co.il
HYP_API_KEY=
HYP_TERMINAL_ID=
HYP_SANDBOX=true

# Fulfillment webhook — שלב 1: יצירת תיקיית Drive + העתקת קבצים (Google Apps Script Web App)
# שרת בלבד, אסור לחשוף לדפדפן
FULFILLMENT_WEBHOOK_URL=
FULFILLMENT_WEBHOOK_SECRET=

# Share webhook — שלב 2: שיתוף התיקייה שנוצרה בשלב 1 עם הלקוח + מייל התראה (shareLib, apps-script/share-lib.gs)
# שרת בלבד, אסור לחשוף לדפדפן. אימות per-customer: לעולם לא לשמור כאן את ה-SECRET של shareLib,
# רק את הטוקן שמתקבל מהרצת _verifyToken() בעורך הסקריפט של shareLib.
SHARE_WEBHOOK_URL=
SHARE_CUSTOMER_EMAIL=silver.chaya@gmail.com
SHARE_CUSTOMER_TOKEN=

# מייל למזכירות — שליחה דרך Gmail SMTP
# MAIL_PASS חייב להיות "App Password" (סיסמת אפליקציה בת 16 תווים) —
# לא הסיסמה הרגילה של חשבון ה-Gmail. ראה CLAUDE/decisions.md / הנחיות בפרויקט להסבר איך משיגים.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_TO=
MAIL_FROM_NAME=יד תמר

# אדמין
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=change_me
JWT_SECRET=replace_with_long_random_string_min_32_chars

# GitHub — Personal Access Token ל-git push מהשרת (scope: repo). לא לחשוף, לא ל-commit.
GITHUB_USER=
GITHUB_TOKEN=
